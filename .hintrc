{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "@page",
          "height: fit-content",
          "scrollbar-color",
          "scrollbar-width",
          "scrollbar-width: thin"
        ]
      }
    ],
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ],
    "no-inline-styles": "off",
    "button-type": "off",
    "detect-css-reflows/composite": "off",
    "axe/text-alternatives": [
      "default",
      {
        "image-alt": "off"
      }
    ],
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 16.5",
    "not safari <= 16.5",
    "not and_chr <= 114",
    "not chrome <= 114",
    "not edge <= 114",
    "not opera <= 99",
    "not samsung <= 21"
  ]
}